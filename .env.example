# Stripe Keys
# Get these from your Stripe Dashboard (Developers > API keys)
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
STRIPE_SECRET_KEY=your_stripe_secret_key

# Firebase Configuration
# Used for push notifications and administrative scripts
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=your_firebase_client_email
FIREBASE_PRIVATE_KEY="your_firebase_private_key"

# Push Server
# URL of your deployed Vercel push-server or local equivalent
PUSH_ENDPOINT=https://your-app.vercel.app/api/send-notification
